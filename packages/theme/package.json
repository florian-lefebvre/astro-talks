{
  "name": "theme",
  "version": "0.0.0",
  "keywords": [
    "slidev-theme",
    "slidev"
  ],
  "engines": {
    "node": ">=22.0.0",
    "slidev": ">=52.0.0"
  },
  "slidev": {
    "colorScheme": "dark",
    "defaults": {
      "fonts": {
        "sans": "Inter, inter-fallback, system-ui, sans-serif",
        "mono": "MDIO, md-io-fallback, monospace",
        "fallbacks": false
      },
      "themeConfig": {
        "primary": "#e8c4f9"
      },
      "transition": "fade"
    }
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@slidev/types": "52.14.1",
    "vite": "8.0.2"
  }
}
